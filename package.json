{
  "name": "lokalite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "lokalite": "./src/cli.ts"
  },
  "scripts": {
    "lokalite": "node ./src/cli.ts",
    "example:agent": "node ./examples/support-agent/server.ts",
    "example:deepseek-agent": "node ./examples/deepseek-support-agent/server.ts",
    "benchmark:deepseek": "node ./examples/deepseek-support-agent/benchmark.ts",
    "benchmark:deepseek-lowresource": "SCENARIO=./examples/scenarios/deepseek-lowresource-refund.yaml node ./examples/deepseek-support-agent/benchmark.ts",
    "benchmark:deepseek-indirect": "SCENARIO=./examples/scenarios/deepseek-indirect-intent.yaml node ./examples/deepseek-support-agent/benchmark.ts",
    "example:deepseek-realistic": "node ./examples/deepseek-support-agent/server-realistic.ts",
    "benchmark:deepseek-realistic": "SCENARIO=./examples/scenarios/deepseek-realistic-routing.yaml node ./examples/deepseek-support-agent/benchmark-realistic.ts",
    "test": "node --test tests/*.test.ts"
  },
  "engines": {
    "node": ">=24"
  }
}
